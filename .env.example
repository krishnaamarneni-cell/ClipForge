# Database (PostgreSQL — use Neon, Supabase, or Vercel Postgres)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Groq API (powers AI analysis, clip generation, and Whisper transcription)
GROQ_API_KEY="gsk_..."

# Perplexity API (fallback if Groq is unavailable)
PERPLEXITY_API_KEY="pplx-..."

# YouTube Data API (for uploading clips to YouTube)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
YOUTUBE_API_KEY=""

# Publishing Integrations
BUFFER_ACCESS_TOKEN=""
MAKE_WEBHOOK_URL=""

# App Config
NEXT_PUBLIC_APP_URL="http://localhost:3040"
FFMPEG_PATH="ffmpeg"
YT_DLP_PATH="yt-dlp"

# Storage (local for MVP, S3 for production)
STORAGE_PATH="./storage"
