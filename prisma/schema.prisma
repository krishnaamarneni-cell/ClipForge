generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id          String   @id @default(uuid())
  title       String
  sourceType  String
  sourceUrl   String?
  fileName    String?
  filePath    String?
  duration    Float?
  thumbnail   String?
  status      String   @default("pending")
  error       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  transcript  Transcript?
  analysis    Analysis?
  clips       Clip[]
  renderJobs  RenderJob[]
}

model Transcript {
  id        String   @id @default(uuid())
  projectId String   @unique
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fullText  String
  segments  String
  language  String   @default("en")
  createdAt DateTime @default(now())
}

model Analysis {
  id             String   @id @default(uuid())
  projectId      String   @unique
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  mainTopic      String
  topics         String
  hooks          String
  emotionalPeaks String
  keyMoments     String
  speakerChanges String
  summary        String
  createdAt      DateTime @default(now())
}

model Clip {
  id              String   @id @default(uuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title           String
  hook            String?
  description     String
  hashtags        String
  startTime       Float
  endTime         Float
  duration        Float
  engagementScore Float
  topicCategory   String
  platforms       String
  captionStyle    String   @default("bold")
  captionData     String?
  titleOverlay    String?
  hookText        String?
  status          String   @default("suggested")
  outputPath      String?
  thumbnailPath   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  renderJobs   RenderJob[]
  publications Publication[]
}

model RenderJob {
  id         String    @id @default(uuid())
  projectId  String
  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  clipId     String
  clip       Clip      @relation(fields: [clipId], references: [id], onDelete: Cascade)
  platform   String
  format     String    @default("mp4")
  resolution String    @default("1080x1920")
  status     String    @default("queued")
  progress   Float     @default(0)
  outputPath String?
  error      String?
  startedAt  DateTime?
  completedAt DateTime?
  createdAt  DateTime  @default(now())
}

model Publication {
  id          String    @id @default(uuid())
  clipId      String
  clip        Clip      @relation(fields: [clipId], references: [id], onDelete: Cascade)
  platform    String
  externalId  String?
  externalUrl String?
  status      String    @default("draft")
  scheduledAt DateTime?
  publishedAt DateTime?
  error       String?
  createdAt   DateTime  @default(now())
}

model Settings {
  id    String @id @default("global")
  data  String
}

model CaptionPreset {
  id         String @id @default(uuid())
  name       String
  style      String
  fontFamily String @default("Inter")
  fontSize   Int    @default(48)
  fontColor  String @default("#FFFFFF")
  bgColor    String?
  position   String @default("center")
  animation  String @default("fade")
  config     String
}
